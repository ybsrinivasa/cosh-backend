# .env — Stage 1 (cosh.dev.eywa.farm)
# Copy to /home/ubuntu/cosh-backend/.env on the server. Never commit this file.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Docker service name is 'postgres' — use that as the host
DATABASE_URL=postgresql+asyncpg://cosh:CHANGE_ME@postgres:5432/cosh_prod
DATABASE_URL_SYNC=postgresql://cosh:CHANGE_ME@postgres:5432/cosh_prod
POSTGRES_DB=cosh_prod
POSTGRES_USER=cosh
POSTGRES_PASSWORD=CHANGE_ME

# ── Neo4J ────────────────────────────────────────────────────────────────────
# Docker service name is 'neo4j'
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD
NEO4J_DATABASE=neo4j

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX

# ── Admin account ────────────────────────────────────────────────────────────
ADMIN_EMAIL=yb@eywa.farm
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://coshdev.eywa.farm

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_MEDIA=tene-drs-prod-media
S3_REGION=ap-south-1
S3_BUCKET_URL=tene-drs-prod-media.s3.ap-south-1.amazonaws.com

# ── Translation ──────────────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=CHANGE_ME
# Leave blank until IndicTrans2 is set up
INDICTRANS2_API_URL=

# ── Email / OTP ──────────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=no-reply@eywa.farm
EMAIL_SMTP_PASS=CHANGE_ME
EMAIL_FROM=no-reply@eywa.farm
EMAIL_REPLY_TO=no-reply@eywa.farm

# ── Sync API keys ────────────────────────────────────────────────────────────
ROOTSTALK_SYNC_API_KEY=CHANGE_ME
PESTEST_SYNC_API_KEY=CHANGE_ME

# ── Monitoring ───────────────────────────────────────────────────────────────
# Optional for Stage 1; set up Sentry project and paste DSN here
SENTRY_DSN=

# ── Similarity ───────────────────────────────────────────────────────────────
SIMILARITY_DETECTION_THRESHOLD=0.80

# ── Frontend API URL ─────────────────────────────────────────────────────────
# Domain: https://coshdev.eywa.farm (SSL handled by infrastructure)
NEXT_PUBLIC_API_URL=https://coshdev.eywa.farm/api

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=staging
