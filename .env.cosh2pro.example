# ──────────────────────────────────────────────────────────────────────────────
# Cosh 2.0 — Production environment template (local server at 106.51.66.90:3860)
# Copy this file to .env on the production server and fill in real values.
# Variable names must match exactly — the app reads them as-is.
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Hostname `postgres` resolves inside Docker compose network
POSTGRES_DB=cosh_prod
POSTGRES_USER=cosh
POSTGRES_PASSWORD=CHANGE_ME_long_random_postgres_password
DATABASE_URL=postgresql+asyncpg://cosh:CHANGE_ME_long_random_postgres_password@postgres:5432/cosh_prod
DATABASE_URL_SYNC=postgresql://cosh:CHANGE_ME_long_random_postgres_password@postgres:5432/cosh_prod

# ── Neo4J ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_long_random_neo4j_password

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_hex_random_string

# ── Admin account (created by seed_db.py on first deploy) ──────────────────────
ADMIN_EMAIL=yb@eywa.farm
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://cosh2.eywa.farm,http://106.51.66.90:3860,http://10.12.10.115:3860

# ── AWS S3 (production media bucket — different prefix from dev) ──────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_MEDIA=tene-drs-prod-media
S3_REGION=ap-south-1
S3_BUCKET_URL=tene-drs-prod-media.s3.ap-south-1.amazonaws.com
# Production prefix to keep separate from dev media (cosh2/media/ is dev's prefix)
S3_KEY_PREFIX=cosh2-prod/media/

# ── Translation ────────────────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=CHANGE_ME

# ── Email / SMTP ───────────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=no-reply@eywa.farm
EMAIL_SMTP_PASS=CHANGE_ME_gmail_app_password
EMAIL_FROM=no-reply@eywa.farm
EMAIL_REPLY_TO=support@eywa.farm

# ── Frontend (used by docker-compose to build cosh-frontend image) ────────────
# Public URL the browser uses to reach the API. Goes through nginx → /api/*
NEXT_PUBLIC_API_URL=https://cosh2.eywa.farm/api
# Server-side URL Next.js uses inside Docker network to reach the API container
INTERNAL_API_URL=http://api:8000
