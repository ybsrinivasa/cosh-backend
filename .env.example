# PostgreSQL
DATABASE_URL=postgresql+asyncpg://cosh:cosh_dev_password@localhost:5432/cosh_dev
DATABASE_URL_SYNC=postgresql://cosh:cosh_dev_password@localhost:5432/cosh_dev

# Neo4J
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=replace-with-a-long-random-string

# Admin account
ADMIN_EMAIL=yb@eywa.farm
ADMIN_PASSWORD=replace-with-your-admin-password

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET_MEDIA=cosh-dev-media
S3_REGION=ap-south-1

# Translation
GOOGLE_TRANSLATE_API_KEY=your-gcp-key

# Environment
ENVIRONMENT=development
